<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: title }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: title }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h1 class="mb-sm">👩‍💼 Perfil de Empleada</h1>
              <p class="text-muted">Seguimiento individual, resumen de actividad y turnos.</p>
            </div>

            <div class="page-actions">
              <a href="/empleados/<%= empleada.id %>/editar" class="btn btn-secondary">Editar</a>
              <a href="/empleados" class="btn btn-secondary">← Volver al listado</a>
            </div>
          </div>

          <h2>
            <%= empleada.nombre %> <%= empleada.apellido || "" %>
          </h2>

          <div class="stats-grid mt-md">
            <div class="stat-card">
              <h4>Turnos realizados</h4>
              <div class="stat-value"><%= metricas.totalTurnos %></div>
            </div>

            <div class="stat-card">
              <h4>Horas trabajadas</h4>
              <div class="stat-value"><%= metricas.horasTrabajadas %> hs</div>
            </div>

            <div class="stat-card">
              <h4>Facturación generada</h4>
              <div class="stat-value">$<%= metricas.facturacionTotal.toLocaleString() %></div>
            </div>

            <div class="stat-card">
              <h4>Comisión estimada</h4>
              <div class="stat-value">$<%= Math.round(metricas.comisionEstimada).toLocaleString() %></div>
            </div>
          </div>

          <hr>

          <h3>Datos de la empleada</h3>
          <ul class="resumen-list">
            <li>📞 Teléfono: <strong><%= empleada.telefono || "-" %></strong></li>
            <li>📧 Email: <strong><%= empleada.email || "-" %></strong></li>
            <li>💰 Comisión: <strong><%= empleada.porcentaje_ganancia %>%</strong></li>
          </ul>

          <hr>

          <h3>🗓 Turnos de la semana</h3>
          <p>
            Semana actual:
            <strong><%= fechaInicio %></strong> al
            <strong><%= fechaFin %></strong>
          </p>

          <% if (!turnosPorDia || Object.keys(turnosPorDia).length === 0) { %>
            <p class="text-muted">Sin turnos registrados en esta semana.</p>
          <% } else { %>
            <% Object.keys(turnosPorDia).forEach(fecha => { %>
              <div class="mt-md">
                <h4>📅 <%= fecha %></h4>

                <div class="table-wrapper">
                  <table>
                    <thead>
                      <tr>
                        <th>Hora</th>
                        <th>Clienta</th>
                        <th>Servicio</th>
                        <th>Duración</th>
                        <th>Costo</th>
                        <th>Estado</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% turnosPorDia[fecha].forEach(t => { %>
                        <tr>
                          <td><%= t.hora %></td>
                          <td><%= t.cliente_nombre %> <%= t.cliente_apellido %></td>
                          <td><%= t.servicio_descripcion %></td>
                          <td><%= t.duracion %> min</td>
                          <td>$<%= Number(t.costo || 0).toLocaleString() %></td>
                          <td><%= t.estado %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }) %>
          <% } %>

          <hr>

          <h3>📅 Historial de turnos</h3>

          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Hora</th>
                  <th>Clienta</th>
                  <th>Servicio</th>
                  <th>Duración</th>
                  <th>Costo</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>
                <% if (turnos.length === 0) { %>
                  <tr>
                    <td colspan="7" class="text-center">Sin turnos registrados</td>
                  </tr>
                <% } %>

                <% turnos.forEach(t => { %>
                  <tr>
                    <td><%= t.fecha %></td>
                    <td><%= t.hora %></td>
                    <td><%= t.cliente_nombre %> <%= t.cliente_apellido %></td>
                    <td><%= t.servicio_descripcion %></td>
                    <td><%= t.duracion %> min</td>
                    <td>$<%= Number(t.costo || 0).toLocaleString() %></td>
                    <td><%= t.estado %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>