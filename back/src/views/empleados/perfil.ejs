<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: title }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: title }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h1 class="mb-sm">👩‍💼 Perfil de Empleada</h1>
              <p class="text-muted">Seguimiento individual, resumen de actividad y turnos.</p>
            </div>

            <div class="page-actions">
              <a href="/empleados/<%= empleada.id %>/editar" class="btn btn-secondary">Editar</a>
              <a href="/empleados" class="btn btn-secondary">← Volver al listado</a>
            </div>
          </div>

          <h2>
            <%= empleada.nombre %> <%= empleada.apellido || "" %>
          </h2>

          <!-- Pestañas -->
<div class="perfil-tabs mt-md">
  <button class="tab-btn active" data-tab="semana">Semana</button>
  <button class="tab-btn" data-tab="mes">Mes</button>
</div>

<!-- Métricas Semana -->
<div class="tab-content" id="tab-semana">
  <div class="stats-grid mt-md">
    <div class="stat-card">
      <h4>Turnos realizados</h4>
      <div class="stat-value"><%= metricasSemana.totalTurnos %></div>
    </div>
    <div class="stat-card">
      <h4>Horas trabajadas</h4>
      <div class="stat-value"><%= metricasSemana.horasTrabajadas %> hs</div>
    </div>
    <div class="stat-card">
      <h4>Facturación generada</h4>
      <div class="stat-value">$<%= metricasSemana.facturacionTotal.toLocaleString() %></div>
    </div>
    <div class="stat-card">
      <h4>Comisión a cobrar</h4>
      <div class="stat-value">$<%= Math.round(metricasSemana.comisionEstimada).toLocaleString() %></div>
    </div>
  </div>

  <div class="table-wrapper mt-md">
    <table>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Hora</th>
          <th>Clienta</th>
          <th>Servicio</th>
          <th>Duración</th>
          <th>Costo</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody>
        <% if (turnosSemana.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center">Sin turnos esta semana</td>
          </tr>
        <% } %>
        <% turnosSemana.forEach(t => { %>
          <tr>
            <td><%= new Date(t.fecha).toLocaleDateString('es-AR') %></td>
            <td><%= t.hora %></td>
            <td><%= t.cliente_nombre %> <%= t.cliente_apellido %></td>
            <td><%= t.servicio_descripcion %></td>
            <td><%= t.duracion %> min</td>
            <td>$<%= Number(t.costo || 0).toLocaleString() %></td>
            <td><%= t.estado %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Métricas Mes -->
<div class="tab-content hidden" id="tab-mes">
  <div class="stats-grid mt-md">
    <div class="stat-card">
      <h4>Turnos realizados</h4>
      <div class="stat-value"><%= metricasMes.totalTurnos %></div>
    </div>
    <div class="stat-card">
      <h4>Horas trabajadas</h4>
      <div class="stat-value"><%= metricasMes.horasTrabajadas %> hs</div>
    </div>
    <div class="stat-card">
      <h4>Facturación generada</h4>
      <div class="stat-value">$<%= metricasMes.facturacionTotal.toLocaleString() %></div>
    </div>
    <div class="stat-card">
      <h4>Comisión a cobrar</h4>
      <div class="stat-value">$<%= Math.round(metricasMes.comisionEstimada).toLocaleString() %></div>
    </div>
  </div>

  <div class="table-wrapper mt-md">
    <table>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Hora</th>
          <th>Clienta</th>
          <th>Servicio</th>
          <th>Duración</th>
          <th>Costo</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody>
        <% if (turnosMes.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center">Sin turnos este mes</td>
          </tr>
        <% } %>
        <% turnosMes.forEach(t => { %>
          <tr>
            <td><%= new Date(t.fecha).toLocaleDateString('es-AR') %></td>
            <td><%= t.hora %></td>
            <td><%= t.cliente_nombre %> <%= t.cliente_apellido %></td>
            <td><%= t.servicio_descripcion %></td>
            <td><%= t.duracion %> min</td>
            <td>$<%= Number(t.costo || 0).toLocaleString() %></td>
            <td><%= t.estado %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

         
          <hr>

          <h3>Datos de la empleada</h3>
          <ul class="resumen-list">
            <li>📞 Teléfono: <strong><%= empleada.telefono || "-" %></strong></li>
            <li>📧 Email: <strong><%= empleada.email || "-" %></strong></li>
            <li>💰 Comisión: <strong><%= empleada.porcentaje_ganancia %>%</strong></li>
          </ul>

        
          
        </section>
      </main>
      <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
          btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            this.classList.add('active');
            document.getElementById('tab-' + this.dataset.tab).classList.remove('hidden');
          });
        });
      </script>
    </div>
  </body>
</html>