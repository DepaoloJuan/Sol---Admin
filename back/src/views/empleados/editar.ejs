<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Editar empleada' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Editar empleada' }) %>

        <section class="content-box">
          <h2>Editar empleada</h2>
          <p class="text-muted mb-md">Actualizá los datos de la empleada.</p>

          <% if (error) { %>
            <p class="mb-md" style="color: var(--color-danger);"><%= error %></p>
          <% } %>

          <form action="/empleados/<%= empleada.id %>/editar" method="POST" class="turno-form">
            <div class="form-grid">
              <div>
                <label for="nombre">Nombre</label>
                <input
                  id="nombre"
                  type="text"
                  name="nombre"
                  value="<%= empleada.nombre || '' %>"
                  required
                />
              </div>

              <div>
                <label for="apellido">Apellido</label>
                <input
                  id="apellido"
                  type="text"
                  name="apellido"
                  value="<%= empleada.apellido || '' %>"
                />
              </div>

              <div>
                <label for="telefono">Teléfono</label>
                <input
                  id="telefono"
                  type="text"
                  name="telefono"
                  value="<%= empleada.telefono || '' %>"
                />
              </div>

              <div>
                <label for="email">Email</label>
                <input
                  id="email"
                  type="email"
                  name="email"
                  value="<%= empleada.email || '' %>"
                />
              </div>

              <div>
                <label for="porcentaje_ganancia">% de ganancia</label>
                <input
                  id="porcentaje_ganancia"
                  type="number"
                  step="0.01"
                  min="0"
                  name="porcentaje_ganancia"
                  value="<%= empleada.porcentaje_ganancia || 0 %>"
                />
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Guardar cambios</button>
              <a href="/empleados" class="btn btn-secondary">Cancelar</a>
            </div>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>