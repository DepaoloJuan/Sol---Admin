<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Nuevo turno', tomSelect: true }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Nuevo turno' }) %>

        <section class="content-box">
          <h2>Crear turno</h2>

          <% if (error) { %>
            <p class="mb-md" style="color: var(--color-danger);"><%= error %></p>
          <% } %>

          <form action="/agenda/nuevo" method="POST" class="turno-form">
            <div class="form-grid">
              <div>
                <label>Fecha</label>
                <input type="date" name="fecha" value="<%= fecha %>" required />
              </div>

              <div>
                <label>Hora</label>
                <input type="time" name="hora" value="<%= hora %>" required />
              </div>

              <div>
                <label>Empleada</label>
                <select name="id_empleado" required>
                  <option value="">Seleccionar</option>
                  <% empleados.forEach(empleado => { %>
                    <option 
                      value="<%= empleado.id %>"
                      <%= empleadoSeleccionado === empleado.id ? 'selected' : '' %>
                    >
                      <%= empleado.nombre %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label>Clienta</label>
                <select name="id_cliente" id="id_cliente" required>
                  <option value="">Seleccionar</option>
                  <% clientes.forEach(cliente => { %>
                    <option
                      value="<%= cliente.id %>"
                      data-search="<%= (cliente.nombre + ' ' + (cliente.apellido || '')).trim() %>"
                    >
                      <%= cliente.nombre %> <%= cliente.apellido || '' %> - <%= cliente.telefono || '' %>
                    </option>
                  <% }) %>
                </select>

                <div class="mt-sm">
                  <a href="/clientes/nuevo?returnTo=/agenda/nuevo&fecha=<%= fecha %>&hora=<%= hora %>&empleado=<%= empleadoSeleccionado %>">
                    + Nueva clienta
                  </a>
                </div>
              </div>

              <div>
                <label>Servicio</label>
                <select name="id_servicio" id="id_servicio" required>
                  <option value="">Seleccionar</option>
                  <% servicios.forEach(servicio => { %>
                    <option
                      value="<%= servicio.id %>"
                      data-precio="<%= servicio.precio || 0 %>"
                      data-duracion="<%= servicio.duracion_sugerida || 30 %>"
                      data-search="<%= servicio.descripcion %>"
                    >
                      <%= servicio.descripcion %> - $<%= servicio.precio || 0 %> - <%= servicio.duracion_sugerida || 30 %> min
                    </option>
                  <% }) %>
                </select>

                <div class="mt-sm">
                  <a href="/servicios/nuevo?returnTo=/agenda/nuevo&fecha=<%= fecha %>&hora=<%= hora %>&empleado=<%= empleadoSeleccionado %>">
                    + Nuevo servicio
                  </a>
                </div>
              </div>

              <div>
                <label>Costo</label>
                <input 
                  type="number" 
                  step="0.01" 
                  min="0"
                  name="costo" 
                  id="costo"
                  placeholder="Ej: 15000"
                  required
                />
              </div>

              <div>
                <label>Duración (minutos)</label>
                <input 
                  type="number"
                  name="duracion"
                  id="duracion"
                  min="10"
                  step="10"
                  value="30"
                  required
                />
              </div>

              <div>
                <label>Estado de pago</label>
                <select name="estado" id="estado">
                  <option value="Pendiente" selected>No pagado</option>
                  <option value="Parcial">Pago parcial / seña</option>
                  <option value="Pagado">Pagado</option>
                </select>
              </div>

              <div>
                <label>Monto abonado</label>
                <input
                  type="number"
                  step="0.01"
                  min="0"
                  name="monto_abonado"
                  id="monto_abonado"
                  value="0"
                />
              </div>

              <div style="grid-column: 1 / -1;">
                <label style="display: flex; align-items: flex-start; gap: 8px;">
                  <input
                    type="checkbox"
                    name="actualizar_servicio_base"
                    value="1"
                  />
                  Actualizar también el precio y la duración sugerida del servicio para próximos turnos
                </label>
              </div>
            </div>

            <div class="mt-lg content-box" style="background: var(--color-surface-soft); box-shadow: none;">
              <h3>Resumen de pago</h3>
              <p><strong>Costo total:</strong> $<span id="resumen_costo">0</span></p>
              <p><strong>Seña / abonado:</strong> $<span id="resumen_abonado">0</span></p>
              <p><strong>Saldo pendiente:</strong> $<span id="resumen_resta">0</span></p>
              <p><strong>Estado final:</strong> <span id="resumen_estado">Pendiente</span></p>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Guardar turno</button>
              <a href="/agenda?fecha=<%= fecha %>" class="btn btn-secondary">Cancelar</a>
            </div>
          </form>
        </section>
      </main>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const servicioSelectEl = document.getElementById("id_servicio");
        const costoInput = document.getElementById("costo");
        const duracionInput = document.getElementById("duracion");
        const estadoSelect = document.getElementById("estado");
        const montoAbonadoInput = document.getElementById("monto_abonado");
        const resumenEstado = document.getElementById("resumen_estado");
        const resumenCosto = document.getElementById("resumen_costo");
        const resumenAbonado = document.getElementById("resumen_abonado");
        const resumenResta = document.getElementById("resumen_resta");

        function numero(valor) {
          const n = Number(valor);
          return isNaN(n) ? 0 : n;
        }

        function actualizarResumen() {
          const costo = numero(costoInput.value);
          let abonado = numero(montoAbonadoInput.value);

          if (abonado < 0) {
            abonado = 0;
            montoAbonadoInput.value = 0;
          }

          if (abonado > costo) {
            abonado = costo;
            montoAbonadoInput.value = costo;
          }

          const estado = estadoSelect.value;

          if (estado === "Pendiente") {
            abonado = 0;
            montoAbonadoInput.value = 0;
            montoAbonadoInput.readOnly = true;
          } else if (estado === "Pagado") {
            abonado = costo;
            montoAbonadoInput.value = costo;
            montoAbonadoInput.readOnly = true;
          } else {
            montoAbonadoInput.readOnly = false;
          }

          const resta = Math.max(costo - abonado, 0);

          resumenCosto.textContent = costo.toLocaleString("es-AR");
          resumenAbonado.textContent = abonado.toLocaleString("es-AR");
          resumenResta.textContent = resta.toLocaleString("es-AR");
          resumenEstado.textContent = estado;
        }

        function aplicarServicio(value) {
          if (!value) return;
          const opt = Array.from(servicioSelectEl.options).find((o) => o.value === value);
          if (opt) {
            const precio = opt.dataset.precio;
            const duracion = opt.dataset.duracion;
            if (precio) costoInput.value = precio;
            if (duracion) duracionInput.value = duracion;
          }
          actualizarResumen();
        }

        new TomSelect("#id_cliente", {
          placeholder: "Buscar clienta...",
          allowEmptyOption: true,
        });

        const tomSelectServicio = new TomSelect("#id_servicio", {
          placeholder: "Buscar servicio...",
          allowEmptyOption: true,
          onChange: function (value) {
            aplicarServicio(value);
          },
        });

        aplicarServicio(tomSelectServicio.getValue());

        costoInput.addEventListener("input", actualizarResumen);
        estadoSelect.addEventListener("change", actualizarResumen);
        montoAbonadoInput.addEventListener("input", actualizarResumen);

        actualizarResumen();
      });
    </script>
  </body>
</html>