<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Editar servicio' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Editar servicio' }) %>

        <section class="content-box">
          <h2>Editar servicio</h2>
          <p class="text-muted mb-md">Actualizá la información del servicio.</p>

          <% if (error) { %>
            <p class="mb-md" style="color: var(--color-danger);"><%= error %></p>
          <% } %>

          <form action="/servicios/<%= servicio.id %>/editar" method="POST" class="turno-form">
            <div class="form-grid">
              <div>
                <label for="descripcion">Descripción</label>
                <input
                  id="descripcion"
                  type="text"
                  name="descripcion"
                  value="<%= servicio.descripcion || '' %>"
                  required
                />
              </div>

              <div>
                <label for="precio">Precio</label>
                <input
                  id="precio"
                  type="number"
                  step="0.01"
                  name="precio"
                  value="<%= servicio.precio || 0 %>"
                />
              </div>

              <div>
                <label for="duracion_sugerida">Duración sugerida (minutos)</label>
                <input
                  id="duracion_sugerida"
                  type="number"
                  name="duracion_sugerida"
                  min="10"
                  step="10"
                  value="<%= servicio.duracion_sugerida || 30 %>"
                />
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Guardar cambios</button>
              <a href="/servicios" class="btn btn-secondary">Cancelar</a>
            </div>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>