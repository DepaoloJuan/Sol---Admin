<!-- Overlay: toque fuera del menú para cerrar -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">

  <div class="sidebar-brand">
    <h2 class="sidebar-title">Sol Cantero</h2>
  </div>

  <nav class="sidebar-nav">
    <% if (user && user.rol === 'admin') { %>
      <a href="/admin">🏠 Inicio</a>
      <a href="/agenda">📅 Agenda</a>
      <a href="/clientes">👥 Clientes</a>
      <a href="/empleados">👩‍💼 Empleados</a>
      <a href="/servicios">✂️ Servicios</a>
      <a href="/reportes">📊 Reportes</a>
      <a href="/usuarios">🔑 Usuarios</a>
    <% } else { %>
      <a href="/mi-panel">📋 Mi Panel</a>
    <% } %>
  </nav>

  <% if (user) { %>
  <div class="sidebar-user">
    <span class="sidebar-user-avatar"><%= user.nombre.charAt(0).toUpperCase() %></span>
    <div class="sidebar-user-info">
      <span class="sidebar-user-name"><%= user.nombre %></span>
      <span class="sidebar-user-role"><%= user.rol === 'admin' ? 'Administrador' : 'Empleada' %></span>
    </div>
  </div>
  <% } %>

</aside>

<script>
  (function () {
    const path = window.location.pathname;
    document.querySelectorAll('.sidebar-nav a').forEach(function (link) {
      const href = link.getAttribute('href');
      const isActive = href === '/admin'
        ? path === '/admin'
        : path.startsWith(href);
      if (isActive) link.classList.add('active');
    });
  })();
</script>
