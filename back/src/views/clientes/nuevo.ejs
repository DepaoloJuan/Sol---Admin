<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Nueva clienta' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Nueva clienta' }) %>

        <section class="content-box">
          <h2>Crear clienta</h2>
          <p class="text-muted mb-md">Cargá una nueva clienta en el sistema.</p>

          <% if (error) { %>
            <p class="mb-md" style="color: var(--color-danger);"><%= error %></p>
          <% } %>

          <form action="/clientes/nuevo" method="POST" class="turno-form">
            <input type="hidden" name="returnTo" value="<%= returnTo %>">
            <input type="hidden" name="fecha" value="<%= fecha %>">
            <input type="hidden" name="hora" value="<%= hora %>">
            <input type="hidden" name="empleado" value="<%= empleado %>">

            <div class="form-grid">
              <div>
                <label for="nombre">Nombre</label>
                <input id="nombre" type="text" name="nombre" required>
              </div>

              <div>
                <label for="apellido">Apellido</label>
                <input id="apellido" type="text" name="apellido" required>
              </div>

              <div>
                <label for="telefono">Teléfono</label>
                <input id="telefono" type="text" name="telefono">
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Guardar clienta</button>

              <a
                href="<%= returnTo %>?fecha=<%= fecha %>&hora=<%= hora %>&empleado=<%= empleado %>"
                class="btn btn-secondary"
              >
                Cancelar
              </a>
            </div>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>