<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Clientas' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Clientas' }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h2 class="mb-sm">Listado de clientas</h2>
              <p class="text-muted">Gestioná clientas, búsquedas e importación/exportación.</p>
            </div>
          </div>

          <div class="toolbar-row">
            <form method="GET" action="/clientes" class="filter-bar">
              <input
                class="w-auto"
                type="text"
                name="q"
                placeholder="Buscar por nombre o apellido"
                value="<%= q %>"
              />
              <button type="submit" class="btn btn-primary">Buscar</button>
              <a href="/clientes" class="btn btn-secondary">Limpiar</a>
            </form>

            <div class="page-actions">
              <a href="/clientes/nuevo" class="btn btn-primary">+ Nueva clienta</a>
              <div class="action-menu">
                <button class="btn btn-secondary action-menu-btn-wide" type="button">📊 Excel ▾</button>
                <div class="action-menu-dropdown excel-dropdown">
                  <a href="/clientes/exportar/excel">⬇️ Exportar Excel</a>
                  <div class="excel-import-item">
                    <form action="/clientes/importar/excel" method="POST" enctype="multipart/form-data">
                      <label class="excel-import-label">⬆️ Importar Excel</label>
                      <input type="file" name="archivo" accept=".xlsx" required />
                      <button type="submit" class="btn btn-primary btn-sm" style="width:100%; margin-top: 6px;">Subir archivo</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- TABLA (desktop) -->
          <div class="table-wrapper mt-md cliente-table">
            <table>
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Apellido</th>
                  <th>Teléfono</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% if (clientes.length === 0) { %>
                  <tr>
                    <td colspan="4" class="text-center">No se encontraron clientas</td>
                  </tr>
                <% } %>
                <% clientes.forEach(cliente => { %>
                  <tr>
                    <td><%= cliente.nombre %></td>
                    <td><%= cliente.apellido || '' %></td>
                    <td><%= cliente.telefono || '' %></td>
                    <td>
                      <div class="action-menu">
                        <button class="action-menu-btn" type="button">⋮</button>
                        <div class="action-menu-dropdown">
                          <a href="/clientes/<%= cliente.id %>/historial">📋 Historial</a>
                          <a href="/clientes/<%= cliente.id %>/editar">✏️ Editar</a>
                          <button
                            type="button"
                            class="menu-item-danger"
                            onclick="showConfirm('¿Eliminar a <%= cliente.nombre %>?', function() { document.getElementById('form-eliminar-<%= cliente.id %>').submit(); })"
                          >🗑️ Eliminar</button>
                        </div>
                      </div>
                      <form
                        action="/clientes/<%= cliente.id %>/eliminar"
                        method="POST"
                        id="form-eliminar-<%= cliente.id %>"
                        style="display:none"
                      ></form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <!-- CARDS (mobile) -->
          <div class="cliente-cards mt-md">
            <% if (clientes.length === 0) { %>
              <p class="text-muted">No se encontraron clientas.</p>
            <% } %>
            <% clientes.forEach(cliente => { %>
              <div class="cliente-card-item">
                <div class="cliente-card-info">
                  <span class="cliente-card-nombre"><%= cliente.nombre %> <%= cliente.apellido || '' %></span>
                  <% if (cliente.telefono) { %>
                    <span class="cliente-card-telefono"><%= cliente.telefono %></span>
                  <% } %>
                </div>
                <div class="action-menu">
                  <button class="action-menu-btn" type="button">⋮</button>
                  <div class="action-menu-dropdown">
                    <a href="/clientes/<%= cliente.id %>/historial">📋 Historial</a>
                    <a href="/clientes/<%= cliente.id %>/editar">✏️ Editar</a>
                    <button
                      type="button"
                      class="menu-item-danger"
                      onclick="showConfirm('¿Eliminar a <%= cliente.nombre %>?', function() { document.getElementById('form-eliminar-<%= cliente.id %>').submit(); })"
                    >🗑️ Eliminar</button>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

        </section>
      </main>
    </div>

    <script>
      document.addEventListener('click', function(e) {
        if (!e.target.closest('.action-menu')) {
          document.querySelectorAll('.action-menu.open').forEach(m => m.classList.remove('open'));
        }
      });

      document.querySelectorAll('.action-menu > button').forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          const menu = this.closest('.action-menu');
          const wasOpen = menu.classList.contains('open');
          document.querySelectorAll('.action-menu.open').forEach(m => m.classList.remove('open'));
          if (!wasOpen) menu.classList.add('open');
        });
      });
    </script>

  <% if (typeof flash !== 'undefined' && flash) { %>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      showToast("<%= flash.mensaje %>", "<%= flash.tipo %>");
    });
  </script>
  <% } %>
  </body>
</html>
