<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Mi Panel' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Mi Panel' }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h1 class="mb-sm">👩‍💼 Mi Panel</h1>
              <p class="text-muted">
                Bienvenida, <strong><%= empleada.nombre %> <%= empleada.apellido || "" %></strong>
              </p>
            </div>
          </div>

          <!-- Pestañas -->
          <div class="perfil-tabs mt-md">
            <button class="tab-btn active" data-tab="semana-actual">Esta Semana</button>
            <button class="tab-btn" data-tab="semana-anterior">Semana Anterior</button>
            <button class="tab-btn" data-tab="semana-siguiente">Semana Siguiente</button>
            <button class="tab-btn" data-tab="mes">Este Mes</button>
            <button class="tab-btn" data-tab="filtro">Filtro</button>
          </div>

          <!-- ESTA SEMANA -->
          <div class="tab-content" id="tab-semana-actual">
            <p class="text-muted mt-md">
              <%= new Date(fechaInicioSemanaActual + 'T12:00:00').toLocaleDateString('es-AR') %>
              al
              <%= new Date(fechaFinSemanaActual + 'T12:00:00').toLocaleDateString('es-AR') %>
            </p>
            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos</h4>
                <div class="stat-value"><%= metricasSemanaActual.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasSemanaActual.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasSemanaActual.comisionEstimada).toLocaleString('es-AR') %></div>
              </div>
            </div>
            <%- include('./partials/tabla-turnos', { turnos: turnosSemanaActual, empleada, mensajeVacio: 'Sin turnos esta semana' }) %>
          </div>

          <!-- SEMANA ANTERIOR -->
          <div class="tab-content hidden" id="tab-semana-anterior">
            <p class="text-muted mt-md">
              <%= new Date(fechaInicioSemanaAnterior + 'T12:00:00').toLocaleDateString('es-AR') %>
              al
              <%= new Date(fechaFinSemanaAnterior + 'T12:00:00').toLocaleDateString('es-AR') %>
            </p>
            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos</h4>
                <div class="stat-value"><%= metricasSemanaAnterior.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasSemanaAnterior.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasSemanaAnterior.comisionEstimada).toLocaleString('es-AR') %></div>
              </div>
            </div>
            <%- include('./partials/tabla-turnos', { turnos: turnosSemanaAnterior, empleada, mensajeVacio: 'Sin turnos la semana anterior' }) %>
          </div>

          <!-- SEMANA SIGUIENTE -->
          <div class="tab-content hidden" id="tab-semana-siguiente">
            <p class="text-muted mt-md">
              <%= new Date(fechaInicioSemanaSiguiente + 'T12:00:00').toLocaleDateString('es-AR') %>
              al
              <%= new Date(fechaFinSemanaSiguiente + 'T12:00:00').toLocaleDateString('es-AR') %>
            </p>
            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos</h4>
                <div class="stat-value"><%= metricasSemanaSiguiente.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasSemanaSiguiente.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasSemanaSiguiente.comisionEstimada).toLocaleString('es-AR') %></div>
              </div>
            </div>
            <%- include('./partials/tabla-turnos', { turnos: turnosSemanaSiguiente, empleada, mensajeVacio: 'Sin turnos la semana siguiente' }) %>
          </div>

          <!-- ESTE MES -->
          <div class="tab-content hidden" id="tab-mes">
            <p class="text-muted mt-md">
              <%= new Date(fechaInicioMes + 'T12:00:00').toLocaleDateString('es-AR') %>
              al
              <%= new Date(fechaFinMes + 'T12:00:00').toLocaleDateString('es-AR') %>
            </p>
            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos</h4>
                <div class="stat-value"><%= metricasMes.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasMes.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasMes.comisionEstimada).toLocaleString('es-AR') %></div>
              </div>
            </div>
            <%- include('./partials/tabla-turnos', { turnos: turnosMes, empleada, mensajeVacio: 'Sin turnos este mes' }) %>
          </div>

          <!-- FILTRO LIBRE -->
          <div class="tab-content hidden" id="tab-filtro">
            <form method="GET" action="/mi-panel" class="filter-bar mt-md">
              <div>
                <label for="desde">Desde</label>
                <input id="desde" class="w-auto" type="date" name="desde" value="<%= desde %>">
              </div>
              <div>
                <label for="hasta">Hasta</label>
                <input id="hasta" class="w-auto" type="date" name="hasta" value="<%= hasta %>">
              </div>
              <div class="mt-lg">
                <button type="submit" class="btn btn-primary">Filtrar</button>
              </div>
            </form>

            <% if (desde && hasta) { %>
              <p class="text-muted mt-md">
                <%= new Date(desde + 'T12:00:00').toLocaleDateString('es-AR') %>
                al
                <%= new Date(hasta + 'T12:00:00').toLocaleDateString('es-AR') %>
              </p>
              <div class="stats-grid mt-md">
                <div class="stat-card">
                  <h4>Turnos</h4>
                  <div class="stat-value"><%= metricasFiltro.totalTurnos %></div>
                </div>
                <div class="stat-card">
                  <h4>Horas trabajadas</h4>
                  <div class="stat-value"><%= metricasFiltro.horasTrabajadas %> hs</div>
                </div>
                <div class="stat-card">
                  <h4>Comisión a cobrar</h4>
                  <div class="stat-value">$<%= Math.round(metricasFiltro.comisionEstimada).toLocaleString('es-AR') %></div>
                </div>
              </div>
              <%- include('./partials/tabla-turnos', { turnos: turnosFiltro, empleada, mensajeVacio: 'Sin turnos en este período' }) %>
            <% } %>
          </div>

        </section>
      </main>
    </div>

    <script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.add('hidden'));
      this.classList.add('active');
      document.getElementById('tab-' + this.dataset.tab).classList.remove('hidden');
    });
  });

  const desdeVal = "<%= desde %>";
  const hastaVal = "<%= hasta %>";
  if (desdeVal && hastaVal) {
    document.querySelector('[data-tab="filtro"]').click();
  }
</script>
  </body>
</html>