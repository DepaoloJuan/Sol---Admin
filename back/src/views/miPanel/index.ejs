<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Mi Panel' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Mi Panel' }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h1 class="mb-sm">Mi Panel</h1>
              <p class="text-muted">
                Bienvenida, <strong><%= empleada.nombre %> <%= empleada.apellido || "" %></strong>
              </p>
            </div>
          </div>

          <!-- Tabs -->
          <div class="perfil-tabs mt-md">
            <button class="tab-btn active" data-tab="hoy">Hoy</button>
            <button class="tab-btn" data-tab="semana">Esta Semana</button>
            <button class="tab-btn" data-tab="mes">Este Mes</button>
          </div>

          <!-- ======================== HOY ======================== -->
          <div class="tab-content" id="tab-hoy">

            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos de hoy</h4>
                <div class="stat-value"><%= metricasHoy.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasHoy.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión del día</h4>
                <div class="stat-value">$<%= Math.round(metricasHoy.comisionEstimada).toLocaleString() %></div>
              </div>
              <div class="stat-card">
                <h4>Propinas del día</h4>
                <div class="stat-value">$<%= Math.round(metricasHoy.totalPropinas).toLocaleString() %></div>
              </div>
            </div>

            <% if (turnosHoy.length === 0) { %>
              <div class="panel-empty mt-md">
                <p>🌸 No tenés turnos hoy. ¡Disfrutá el descanso!</p>
              </div>
            <% } else { %>
              <div class="agenda-panel mt-md">
                <% turnosHoy.forEach(t => { %>
                  <div class="agenda-panel-row">
                    <div class="agenda-panel-hora">
                      <%= String(t.hora).slice(0, 5) %>
                    </div>
                    <div class="agenda-panel-card">
                      <div class="agenda-panel-servicio"><%= t.servicio_descripcion %></div>
                      <div class="agenda-panel-clienta">👤 <%= t.cliente_nombre %> <%= t.cliente_apellido || "" %></div>
                      <div class="agenda-panel-meta">
                        <span>⏱ <%= t.duracion %> min</span>
                        <span>💰 $<%= Math.round(Number(t.costo || 0) * (empleada.porcentaje_ganancia / 100)).toLocaleString() %> comisión</span>
                        <% if (Number(t.propina || 0) > 0) { %>
                          <span class="agenda-panel-propina">🎁 $<%= Number(t.propina).toLocaleString() %> propina</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>

          </div>

          <!-- ======================== SEMANA ======================== -->
          <div class="tab-content hidden" id="tab-semana">

            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos de la semana</h4>
                <div class="stat-value"><%= metricasSemana.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasSemana.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasSemana.comisionEstimada).toLocaleString() %></div>
              </div>
              <div class="stat-card">
                <h4>Propinas de la semana</h4>
                <div class="stat-value">$<%= Math.round(metricasSemana.totalPropinas).toLocaleString() %></div>
              </div>
            </div>

            <% if (turnosSemana.length === 0) { %>
              <div class="panel-empty mt-md">
                <p>🌸 No tenés turnos esta semana.</p>
              </div>
            <% } else { %>
              <%
                // Agrupar por fecha
                const porDia = {};
                turnosSemana.forEach(t => {
                  const key = new Date(t.fecha).toISOString().split('T')[0];
                  if (!porDia[key]) porDia[key] = [];
                  porDia[key].push(t);
                });
                const diasOrdenados = Object.keys(porDia).sort();
              %>
              <% diasOrdenados.forEach(fecha => { %>
                <%
                  const d = new Date(fecha + 'T12:00:00');
                  const nombreDia = d.toLocaleDateString('es-AR', { weekday: 'long', day: 'numeric', month: 'long' });
                %>
                <div class="agenda-panel-dia mt-md">
                  <div class="agenda-panel-dia-header">
                    📅 <%= nombreDia.charAt(0).toUpperCase() + nombreDia.slice(1) %>
                  </div>
                  <div class="agenda-panel mt-sm">
                    <% porDia[fecha].forEach(t => { %>
                      <div class="agenda-panel-row">
                        <div class="agenda-panel-hora">
                          <%= String(t.hora).slice(0, 5) %>
                        </div>
                        <div class="agenda-panel-card">
                          <div class="agenda-panel-servicio"><%= t.servicio_descripcion %></div>
                          <div class="agenda-panel-clienta">👤 <%= t.cliente_nombre %> <%= t.cliente_apellido || "" %></div>
                          <div class="agenda-panel-meta">
                            <span>⏱ <%= t.duracion %> min</span>
                            <span>💰 $<%= Math.round(Number(t.costo || 0) * (empleada.porcentaje_ganancia / 100)).toLocaleString() %> comisión</span>
                            <% if (Number(t.propina || 0) > 0) { %>
                              <span class="agenda-panel-propina">🎁 $<%= Number(t.propina).toLocaleString() %> propina</span>
                            <% } %>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            <% } %>

          </div>

          <!-- ======================== MES ======================== -->
          <div class="tab-content hidden" id="tab-mes">

            <div class="stats-grid mt-md">
              <div class="stat-card">
                <h4>Turnos del mes</h4>
                <div class="stat-value"><%= metricasMes.totalTurnos %></div>
              </div>
              <div class="stat-card">
                <h4>Horas trabajadas</h4>
                <div class="stat-value"><%= metricasMes.horasTrabajadas %> hs</div>
              </div>
              <div class="stat-card">
                <h4>Comisión a cobrar</h4>
                <div class="stat-value">$<%= Math.round(metricasMes.comisionEstimada).toLocaleString() %></div>
              </div>
              <div class="stat-card">
                <h4>Propinas del mes</h4>
                <div class="stat-value">$<%= Math.round(metricasMes.totalPropinas).toLocaleString() %></div>
              </div>
            </div>

            <% if (turnosMes.length === 0) { %>
              <div class="panel-empty mt-md">
                <p>🌸 No tenés turnos este mes.</p>
              </div>
            <% } else { %>
              <div class="table-wrapper mt-md">
                <table>
                  <thead>
                    <tr>
                      <th>Fecha</th>
                      <th>Hora</th>
                      <th>Clienta</th>
                      <th>Servicio</th>
                      <th>Duración</th>
                      <th>Comisión</th>
                      <th>Propina</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% turnosMes.forEach(t => { %>
                      <tr>
                        <td><%= new Date(t.fecha + 'T12:00:00').toLocaleDateString('es-AR') %></td>
                        <td><%= String(t.hora).slice(0, 5) %></td>
                        <td><%= t.cliente_nombre %> <%= t.cliente_apellido || "" %></td>
                        <td><%= t.servicio_descripcion %></td>
                        <td><%= t.duracion %> min</td>
                        <td>$<%= Math.round(Number(t.costo || 0) * (empleada.porcentaje_ganancia / 100)).toLocaleString() %></td>
                        <td><%= Number(t.propina || 0) > 0 ? '$' + Number(t.propina).toLocaleString() : '-' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>

          </div>

        </section>
      </main>
    </div>

    <script>
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
          this.classList.add('active');
          document.getElementById('tab-' + this.dataset.tab).classList.remove('hidden');
        });
      });
    </script>
  </body>
</html>