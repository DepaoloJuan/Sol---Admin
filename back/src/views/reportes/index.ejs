<!DOCTYPE html>
<html lang="es">
  <%- include('../partials/head', { title: 'Reportes' }) %>
  <body>
    <div class="layout">
      <%- include('../partials/sidebar') %>

      <main class="main-content">
        <%- include('../partials/header', { title: 'Reportes' }) %>

        <section class="content-box">
          <div class="topbar mb-md">
            <div>
              <h2 class="mb-sm">📊 Reportes Generales</h2>
              <p class="text-muted">
                Control financiero del negocio: turnos, cobros, deuda, gastos y ganancia neta.
              </p>
            </div>
          </div>

          <div class="filter-quick mb-md">
            <span class="text-muted">Accesos rápidos:</span>
            <button type="button" class="btn btn-secondary btn-sm" data-range="hoy">Hoy</button>
            <button type="button" class="btn btn-secondary btn-sm" data-range="semana">Esta Semana</button>
            <button type="button" class="btn btn-secondary btn-sm" data-range="mes">Este Mes</button>
          </div>

          <form method="GET" action="/reportes" id="filter-form" class="filter-bar">
            <div>
              <label for="desde">Desde</label>
              <input id="desde" class="w-auto" type="date" name="desde" value="<%= desde %>">
            </div>

            <div>
              <label for="hasta">Hasta</label>
              <input id="hasta" class="w-auto" type="date" name="hasta" value="<%= hasta %>">
            </div>

            <div class="mt-lg">
              <button type="submit" class="btn btn-primary">Filtrar</button>
            </div>
          </form>

          <div class="stats-grid mt-lg">
            <div class="stat-card">
              <h4>Total turnos</h4>
              <div class="stat-value"><%= resumen.totalTurnos %></div>
            </div>

            <div class="stat-card">
              <h4>Facturación total</h4>
              <div class="stat-value">$<%= resumen.totalFacturado.toLocaleString() %></div>
            </div>

            <div class="stat-card">
              <h4>Total cobrado</h4>
              <div class="stat-value">$<%= resumen.totalCobrado.toLocaleString() %></div>
            </div>

            <div class="stat-card">
              <h4>Deuda pendiente</h4>
              <div class="stat-value">$<%= resumen.totalDeuda.toLocaleString() %></div>
            </div>

            <div class="stat-card">
              <h4>Total gastos</h4>
              <div class="stat-value">$<%= resumen.totalGastos.toLocaleString() %></div>
            </div>

            <div class="stat-card">
              <h4>Ganancia neta</h4>
              <div class="stat-value">$<%= resumen.gananciaNeta.toLocaleString() %></div>
            </div>
          </div>

          <hr>

          <h3>💸 Registrar gasto</h3>
          <p class="text-muted mb-md">
            Cargá egresos cotidianos, insumos o compras para descontarlos del resultado real.
          </p>

          <% if (typeof errorGasto !== "undefined") { %>
            <p class="text-danger"><%= errorGasto %></p>
          <% } %>

          <form id="gasto-form" action="<%= gastoEditandoId ? '/reportes/gastos/update/' + gastoEditandoId : '/reportes/gastos/nuevo' %>" method="POST" class="turno-form">
            <input type="hidden" name="desde" value="<%= desde %>">
            <input type="hidden" name="hasta" value="<%= hasta %>">
            <div class="form-grid">
              <div>
                <label for="fecha">Fecha</label>
                <input
                  id="fecha"
                  type="date"
                  name="fecha"
                  value="<%= (gastoForm && gastoForm.fecha) ? gastoForm.fecha : hasta %>"
                  required
                />
              </div>

              <div>
                <label for="descripcion">Descripción</label>
                <input
                  id="descripcion"
                  type="text"
                  name="descripcion"
                  placeholder="Ej: Compra de esmaltes"
                  value="<%= (gastoForm && gastoForm.descripcion) ? gastoForm.descripcion : '' %>"
                  required
                />
              </div>

              <div>
                <label for="monto">Monto</label>
                <input
                  id="monto"
                  type="number"
                  name="monto"
                  step="0.01"
                  min="0"
                  placeholder="Ej: 15000"
                  value="<%= (gastoForm && gastoForm.monto) ? gastoForm.monto : '' %>"
                  required
                />
              </div>

              <div>
                <label for="categoria">Categoría</label>
                <input
                  id="categoria"
                  type="text"
                  name="categoria"
                  placeholder="Ej: Insumos"
                  value="<%= (gastoForm && gastoForm.categoria) ? gastoForm.categoria : '' %>"
                />
              </div>

              <div style="grid-column: 1 / -1;">
                <label for="observaciones">Observaciones</label>
                <textarea
                  id="observaciones"
                  name="observaciones"
                  placeholder="Detalle opcional"
                ><%= (gastoForm && gastoForm.observaciones) ? gastoForm.observaciones : '' %></textarea>
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" id="gasto-submit-btn" class="btn <%= gastoEditandoId ? 'btn-update' : 'btn-primary' %>">
                <%= gastoEditandoId ? 'Actualizar gasto' : 'Guardar gasto' %>
              </button>
              <% if (gastoEditandoId) { %>
              <a href="/reportes?desde=<%= desde %>&hasta=<%= hasta %>" class="btn btn-secondary ml-sm">Cancelar edición</a>
              <% } %>
            </div>
          </form>

          <hr>

          <h3>🧾 Gastos del período</h3>

          <div class="table-wrapper mt-md">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Descripción</th>
                  <th>Monto</th>
                  <th>Categoría</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% if (!gastos || gastos.length === 0) { %>
                  <tr>
                    <td colspan="5" class="text-center">No hay gastos cargados en este período</td>
                  </tr>
                <% } %>

                <% gastos.forEach(g => { %>
                  <tr data-gasto-id="<%= g.id %>"
                      data-fecha="<%= g.fecha ? (typeof g.fecha === 'string' ? g.fecha : new Date(g.fecha).toISOString().split('T')[0]) : '' %>"
                      data-descripcion="<%= (g.descripcion || '').replace(/"/g, '&quot;') %>"
                      data-monto="<%= g.monto %>"
                      data-categoria="<%= (g.categoria || '').replace(/"/g, '&quot;') %>"
                      data-observaciones="<%= (g.observaciones || '').replace(/"/g, '&quot;').replace(/\n/g, '&#10;') %>">
                    <td><%= new Date(g.fecha).toLocaleDateString('es-AR') %></td>
                    <td><%= g.descripcion %></td>
                    <td>$<%= Number(g.monto || 0).toLocaleString() %></td>
                    <td><%= g.categoria || '-' %></td>
                    <td class="gasto-actions">
                      <button type="button" class="btn-icon btn-edit btn-editar-gasto" title="Editar">&#9998;</button>
                      <form action="/reportes/gastos/delete/<%= g.id %>" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este gasto?');">
                        <input type="hidden" name="desde" value="<%= desde %>">
                        <input type="hidden" name="hasta" value="<%= hasta %>">
                        <button type="submit" class="btn-icon btn-delete" title="Eliminar">&#128465;</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <hr>

          <h3>📅 Turnos del período</h3>

          <div class="table-wrapper mt-md">
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Hora</th>
                  <th>Costo</th>
                  <th>Abonado</th>
                  <th>Deuda</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>
                <% if (!turnos || turnos.length === 0) { %>
                  <tr>
                    <td colspan="6" class="text-center">No hay turnos en este período</td>
                  </tr>
                <% } %>

                <% turnos.forEach(t => { %>
                  <tr>
                    <td><%= new Date(t.fecha).toLocaleDateString('es-AR') %></td>
                    <td><%= t.hora %></td>
                    <td>$<%= Number(t.costo || 0).toLocaleString() %></td>
                    <td>
                      $<%= (t.estado === 'Pagado'
                        ? Number(t.costo || 0)
                        : Number(t.monto_abonado || 0)
                      ).toLocaleString() %>
                    </td>
                    <td>
                      $<%= (t.estado === 'Pagado'
                        ? 0
                        : Number(t.costo || 0) - Number(t.monto_abonado || 0)
                      ).toLocaleString() %>
                    </td>
                    <td><%= t.estado %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <script>
      (function () {
        const filterForm = document.getElementById("filter-form");
        const desdeInput = document.getElementById("desde");
        const hastaInput = document.getElementById("hasta");
        const gastoForm = document.getElementById("gasto-form");
        const gastoSubmitBtn = document.getElementById("gasto-submit-btn");
        const formatDate = (d) => d.toISOString().split("T")[0];

        document.querySelectorAll("[data-range]").forEach(function (btn) {
          btn.addEventListener("click", function () {
            const hoy = new Date();
            const range = this.dataset.range;
            if (range === "hoy") {
              desdeInput.value = formatDate(hoy);
              hastaInput.value = formatDate(hoy);
            } else if (range === "semana") {
              const day = hoy.getDay();
              const diff = day === 0 ? -6 : 1 - day;
              const lunes = new Date(hoy);
              lunes.setDate(hoy.getDate() + diff);
              const domingo = new Date(lunes);
              domingo.setDate(lunes.getDate() + 6);
              desdeInput.value = formatDate(lunes);
              hastaInput.value = formatDate(domingo);
            } else if (range === "mes") {
              const inicio = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
              const fin = new Date(hoy.getFullYear(), hoy.getMonth() + 1, 0);
              desdeInput.value = formatDate(inicio);
              hastaInput.value = formatDate(fin);
            }
            filterForm.submit();
          });
        });

        document.querySelectorAll(".btn-editar-gasto").forEach(function (btn) {
          btn.addEventListener("click", function () {
            const row = this.closest("tr");
            const id = row.dataset.gastoId;
            const fecha = row.dataset.fecha;
            const descripcion = row.dataset.descripcion || "";
            const monto = row.dataset.monto || "";
            const categoria = row.dataset.categoria || "";
            const observaciones = row.dataset.observaciones || "";

            gastoForm.action = "/reportes/gastos/update/" + id;
            gastoForm.querySelector("[name=fecha]").value = fecha;
            gastoForm.querySelector("[name=descripcion]").value = descripcion;
            gastoForm.querySelector("[name=monto]").value = Math.round(Number(monto));
            gastoForm.querySelector("[name=categoria]").value = categoria;
            gastoForm.querySelector("[name=observaciones]").value = observaciones.replace(/&#10;/g, "\n");

            gastoSubmitBtn.textContent = "Actualizar gasto";
            gastoSubmitBtn.className = "btn btn-update";

            gastoForm.scrollIntoView({ behavior: "smooth" });
          });
        });
      })();
    </script>
  </body>
</html>